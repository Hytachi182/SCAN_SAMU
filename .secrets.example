# URL de base GitLab, sans slash final
GITLAB_BASE_URL=https://gitlab.example.com

# Path du groupe ou sous-groupe à scanner
GITLAB_GROUP_PATH=my-group/my-subgroup

# Token GitLab avec accès en lecture API + dépôts
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Branche à utiliser si GitLab ne remonte pas de default branch
DEFAULT_FALLBACK_BRANCH=main

# Répertoire racine de travail
WORKSPACE_DIR=./data

# Nom de l'image locale utilisée pour detect-secrets
DETECT_SECRETS_IMAGE=scan-secrets/detect-secrets:local

# Images essayées pour Gitleaks, dans l'ordre
GITLEAKS_IMAGES=ghcr.io/gitleaks/gitleaks:latest,zricethezav/gitleaks:latest

# Images essayées pour TruffleHog, dans l'ordre
TRUFFLEHOG_IMAGES=trufflesecurity/trufflehog:latest

# Image et règles Semgrep
SEMGREP_IMAGES=semgrep/semgrep:latest
SEMGREP_CONFIGS=/rules/semgrep-secrets.yml,p/secrets
