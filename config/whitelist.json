{
  "paths": [
    "(?i)(^|[\\\\/])node_modules([\\\\/]|$)",
    "(?i)(^|[\\\\/])vendor([\\\\/]|$)"
  ],
  "secrets": [
    "(?i)dummy[_-]?password",
    "(?i)example[_-]?token",
    "(?i)changeme"
  ],
  "rules": [
    {
      "reason": "Test fixtures and sample data",
      "repoPattern": ".*",
      "filePattern": "(?i)(^|[\\\\/])(tests?|fixtures?|samples?)([\\\\/]|$)"
    },
    {
      "reason": "Proxy password placeholder example",
      "detectors": [
        "semgrep",
        "heuristic"
      ],
      "repoPattern": ".*",
      "filePattern": "^example/group_vars/all/secret\\.example\\.yml$",
      "linePattern": "(?i)^\\s*proxy_password\\s*:\\s*password\\s*$"
    },
    {
      "reason": "Proxy password templated variable reference",
      "detectors": [
        "semgrep"
      ],
      "ruleIds": [
        "rules.generic-hardcoded-password-assignment"
      ],
      "repoPattern": ".*",
      "filePattern": "^roles/configure_vm/tasks/docker\\.yml$",
      "linePattern": "(?i)proxy_password\\s*\\|\\s*urlencode"
    },
    {
      "reason": "Allowlist inline detect-secrets",
      "detectors": [
        "detect-secrets"
      ],
      "ruleIds": [
        "Inline Allowlist"
      ]
    },
    {
      "reason": "js-tokens is a well-known npm package, not a secret",
      "detectors": [
        "semgrep"
      ],
      "ruleIds": [
        "rules.generic-hardcoded-secret-assignment"
      ],
      "repoPattern": ".*",
      "filePattern": "(?i)(^|[\\\\/])package-lock\\.json$",
      "linePattern": "\"js-tokens\"\\s*:\\s*\"\\^4\\.0\\.0\""
    },
    {
      "reason": "Ansible templated variable reference, not a hardcoded secret",
      "detectors": [
        "semgrep",
        "heuristic",
        "detect-secrets",
        "gitleaks",
        "trufflehog"
      ],
      "repoPattern": ".*",
      "filePattern": ".*\\.yml$",
      "linePattern": "(?i)password_credential\\s*:\\s*\"\\{\\{\\s*item\\.password\\s*\\}\\}\""
    },
    {
      "reason": "NETBOX_TOKEN is a placeholder/dummy token used in functional tests Dockerfile",
      "detectors": [
        "semgrep",
        "heuristic",
        "detect-secrets",
        "gitleaks",
        "trufflehog"
      ],
      "repoPattern": ".*",
      "filePattern": "(?i)(^|[\\\\/])Dockerfile$",
      "linePattern": "(?i)^ENV\\s+NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567\\s*$"
    },
    {
      "reason": "Function parameter default value, not a hardcoded secret",
      "detectors": [
        "semgrep",
        "heuristic",
        "detect-secrets",
        "gitleaks",
        "trufflehog"
      ],
      "repoPattern": ".*",
      "filePattern": "(?i)(^|[\\\\/])ldapwrapper\\.py$",
      "linePattern": "(?i)def\\s+__init__\\s*\\(.*password\\s*=\\s*None.*\\)"
    },
    {
      "reason": "Ansible Jinja2 templated proxy username reference, not a hardcoded secret",
      "detectors": [
        "semgrep",
        "heuristic",
        "detect-secrets",
        "gitleaks",
        "trufflehog"
      ],
      "repoPattern": ".*",
      "filePattern": ".*\\.yml$",
      "linePattern": "(?i)proxy_username\\s*\\|\\s*urlencode"
    },
    {
      "reason": "Nil UUID placeholder used as example in documentation, not a real secret",
      "detectors": [
        "semgrep",
        "heuristic",
        "detect-secrets",
        "gitleaks",
        "trufflehog"
      ],
      "repoPattern": ".*",
      "filePattern": "(?i)(^|[\\\\/])README\\.md$",
      "linePattern": "(?i)secret_id\\s*=\\s*\"00000000-0000-0000-0000-000000000000\""
    }
  ]
}
